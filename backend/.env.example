# ─── SmartFix Tanzania — Environment Variables ───────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# ── App ──────────────────────────────────────────────────────
APP_ENV=development        # development | production
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://smartfix_user:password@localhost:5432/smartfix_db
# For Supabase: get this from your Supabase dashboard → Settings → Database

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# For Upstash: get from upstash.com dashboard

# ── Stripe (International Cards) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Flutterwave (Mobile Money - Tanzania) ─────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_ENCRYPTION_KEY=...
FLUTTERWAVE_WEBHOOK_SECRET=...

# ── Africa's Talking (SMS) ────────────────────────────────────
AT_USERNAME=sandbox       # your Africa's Talking username
AT_API_KEY=...
AT_SENDER_ID=SmartFix

# ── Google Maps (optional - for technician location) ──────────
GOOGLE_MAPS_API_KEY=...
